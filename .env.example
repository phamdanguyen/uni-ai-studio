# WAOO Studio - Environment Variables
# Copy this to .env and fill in your values

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=waoo
DB_PASSWORD=waoo_secret
DB_NAME=waoo_studio
DB_SSLMODE=disable
DB_MAX_CONNS=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- S3/MinIO ---
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=waoo-media

# --- LLM Providers ---
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GOOGLE_AI_KEY=
ANTHROPIC_KEY=

# --- Media Generation Providers ---
FAL_API_KEY=
ARK_API_KEY=
MINIMAX_API_KEY=
VIDU_API_KEY=

# --- Model Routing ---
LLM_FLASH_MODEL=google/gemini-2.0-flash-exp
LLM_STANDARD_MODEL=anthropic/claude-sonnet-4-20250514
LLM_PREMIUM_MODEL=anthropic/claude-opus-4-20250514
LLM_DEFAULT_BUDGET_USD=10.0
LLM_REQUEST_TIMEOUT_S=120
